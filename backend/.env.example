# ==============================
# FF Arena Backend - Environment
# ==============================

# MongoDB Atlas connection string
# Get free DB at: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/ff-arena?retryWrites=true&w=majority

# JWT secrets — change these to long random strings
JWT_SECRET=ff_arena_jwt_secret_change_this_to_something_long_random_2024
JWT_REFRESH_SECRET=ff_arena_refresh_secret_change_this_too_2024

# Razorpay — get keys at razorpay.com (test mode is free)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXX

# Admin credentials for first login
ADMIN_EMAIL=admin@ffarena.com
ADMIN_PASSWORD=FreeFire@Admin2024

# Server
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000
